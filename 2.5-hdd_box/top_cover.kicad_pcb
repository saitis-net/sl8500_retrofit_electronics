	(gr_text "Cette cartouche est la propriété insaisissable de son utilisateur.\nPour des raisons évidentes d'anonymisation, la relation entre\nle numéro de cartouche (affiché sur la face avant) et son propriétaire\nest conservé par des tiers de confiance.\n\nSi la cartouche est dans une librairie automatique, ces tiers\nde confiance sont affichés sur la machine ou sur un mur de façon\nbien visible.\n"
		(at 56.8 71.1 0)
		(layer "F.SilkS")
		(uuid "056273c9-bfb5-4a36-92b3-241c082fadc2")
		(effects
			(font
				(size 2 2)
				(thickness 0.2)
			)
			(justify left bottom)
		)
	)
