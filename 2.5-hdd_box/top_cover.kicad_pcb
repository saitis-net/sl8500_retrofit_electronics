	(gr_text "This is\nnot USB"
		(at 144 121.7 0)
		(layer "F.SilkS")
		(uuid "d9438af7-265d-4df2-9c8e-9e6cb0fc2840")
		(effects
			(font
				(size 3 3)
				(thickness 0.3)
			)
			(justify left bottom)
		)
	)
	(gr_text "USB3 supports alternate modes (display, audio)\nbut SATA has not been specified.\nSATA impedance is quite similar.\nUSB type B connector is much more rugged than SATA,\neven eSATA. Our is rated 5000 cycles.\nAnd it's better not to wear the HDD connector."
		(at 149.3 65.4 0)
		(layer "B.SilkS")
		(uuid "cd3faa86-44b3-4890-944b-4f8d77d407dc")
		(effects
			(font
				(size 2 2)
				(thickness 0.2)
			)
			(justify left bottom mirror)
		)
	)
