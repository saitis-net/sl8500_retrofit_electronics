	(gr_text "Front PCB must be cut to become the back PCB\nSoldier PAD are placed by eye"
		(at 50.6 99 0)
		(layer "Edge.Cuts")
		(uuid "15922295-38a8-47aa-bda2-93a4508d1924")
		(effects
